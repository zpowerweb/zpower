msgid "輪播圖"
msgstr "Slider"

msgid "新增輪播圖"
msgstr "Add New Slider"

msgid "編輯輪播圖"
msgstr "Edit Slider"

msgid "新輪播圖"
msgstr "New Slider"

msgid "所有輪播圖"
msgstr "All Sliders"

msgid "檢視輪播圖"
msgstr "View Slider"

msgid "搜尋輪播圖"
msgstr "Search Sliders"

msgid "找不到輪播圖"
msgstr "No sliders found"

msgid "垃圾桶內無輪播圖"
msgstr "No sliders found in Trash"

msgid "輪播圖設定"
msgstr "Slider Settings"

msgid "您沒有權限進行此操作"
msgstr "You do not have permission to perform this action."

msgid "設定已儲存。"
msgstr "Settings saved."

msgid "輪播圖權限設定"
msgstr "Slider Permission Settings"

msgid "僅限管理員/編輯可編輯輪播圖"
msgstr "Only administrators and editors can edit sliders"

msgid "為了安全性，輪播圖固定只有管理員與編輯可以新增、編輯、刪除。"
msgstr "For security, only administrators and editors can add, edit, and delete sliders."

msgid "儲存設定"
msgstr "Save Settings"

msgid "目前僅限管理員與編輯人員可以編輯輪播圖。"
msgstr "Only administrators and editors can edit sliders."

msgid "目前僅限管理員與編輯人員可以新增輪播圖。"
msgstr "Only administrators and editors can add sliders."

msgid "輪播圖片與設定"
msgstr "Slider Images and Settings"

msgid "您沒有編輯此輪播圖的權限。"
msgstr "You do not have permission to edit this slider."

msgid "輪播模式設定"
msgstr "Slider Mode Settings"

msgid "啟用自動抓取文章輪播"
msgstr "Enable automatic post slider"

msgid "啟用後，將自動抓取文章作為輪播內容。停用則使用手動輪播設定。"
msgstr "When enabled, posts are automatically used as slider content. When disabled, manual slider settings are used."

msgid "自動文章輪播設定"
msgstr "Automatic Post Slider Settings"

msgid "選擇文章分類"
msgstr "Select Post Category"

msgid "所有分類"
msgstr "All Categories"

msgid "選擇要輪播的文章分類，預設顯示最新 10 篇文章。"
msgstr "Select the post category to display. By default, the latest 10 posts are shown."

msgid "文章標題樣式設定"
msgstr "Post Title Style Settings"

msgid "標題文字大小 (桌面)"
msgstr "Title Font Size (Desktop)"

msgid "標題文字大小 (平板)"
msgstr "Title Font Size (Tablet)"

msgid "建議寬度 <= 1024px"
msgstr "Recommended width <= 1024px"

msgid "標題文字大小 (手機)"
msgstr "Title Font Size (Mobile)"

msgid "建議寬度 <= 768px"
msgstr "Recommended width <= 768px"

msgid "標題背景高度 (桌面)"
msgstr "Title Background Height (Desktop)"

msgid "標題背景高度 (平板)"
msgstr "Title Background Height (Tablet)"

msgid "標題背景高度 (手機)"
msgstr "Title Background Height (Mobile)"

msgid "標題文字左右內距"
msgstr "Title Horizontal Padding"

msgid "標題文字置中對齊"
msgstr "Center align title text"

msgid "標題文字顏色"
msgstr "Title Text Color"

msgid "不透明度"
msgstr "opacity"

msgid "標題背景顏色"
msgstr "Title Background Color"

msgid "標題樣式預設值"
msgstr "Reset Title Style"

msgid "輪播區塊固定高度設定"
msgstr "Fixed Slider Height Settings"

msgid "啟用固定輪播高度"
msgstr "Enable fixed slider height"

msgid "啟用後，下方設定的高度將會生效，圖片將填滿寬度並置中顯示，超出高度的部分會被裁切。"
msgstr "When enabled, the height settings below take effect. Images fill the width, stay centered, and overflow is cropped."

msgid "輪播區塊高度 (桌面)"
msgstr "Slider Height (Desktop)"

msgid "輪播區塊高度 (平板)"
msgstr "Slider Height (Tablet)"

msgid "輪播區塊高度 (手機)"
msgstr "Slider Height (Mobile)"

msgid "輪播通用設定"
msgstr "General Slider Settings"

msgid "此處設定適用於手動輪播及自動抓取文章輪播的通用外觀與行為。"
msgstr "These settings apply to the shared appearance and behavior of manual sliders and automatic post sliders."

msgid "輪播樣式"
msgstr "Slider Style"

msgid "選擇前台輪播版型。樣式一為滿版輪播；樣式二會顯示白色背景、中央圓角圖片與左右露出的前後張。"
msgstr "Select the frontend slider layout. Style 1 is full-width. Style 2 uses a white background, rounded center image, and partially visible previous/next slides."

msgid "樣式一"
msgstr "Style 1"

msgid "滿版輪播圖顯示方式。"
msgstr "Full-width slider display."

msgid "樣式二"
msgstr "Style 2"

msgid "中央主圖放大，進入頁面即可看到左中右三張，外層使用白色背景與圓角卡片效果。"
msgstr "The center image is emphasized, with left and right slides visible on page load and a white rounded-card effect."

msgid "樣式二圖片圓角"
msgstr "Style 2 Image Radius"

msgid "此設定只會套用於樣式二；設為 0px 可取消圖片圓角。"
msgstr "This setting only applies to Style 2. Set it to 0px to remove image rounding."

msgid "顏色設定"
msgstr "Color Settings"

msgid "這些顏色設定將應用於輪播的導覽箭頭與分頁點。"
msgstr "These color settings apply to the slider arrows and pagination dots."

msgid "箭頭顏色"
msgstr "Arrow Color"

msgid "點的顏色"
msgstr "Dot Color"

msgid "圖示設定（點及箭頭）"
msgstr "Icon Settings (Dots and Arrows)"

msgid "調整輪播導覽箭頭與分頁點的尺寸、邊距等外觀設定。"
msgstr "Adjust size, spacing, and other appearance settings for slider arrows and pagination dots."

msgid "箭頭大小"
msgstr "Arrow Size"

msgid "箭頭左右邊距"
msgstr "Arrow Side Margin"

msgid "點的大小"
msgstr "Dot Size"

msgid "點與點之間的距離"
msgstr "Dot Gap"

msgid "點與底部的距離"
msgstr "Dot Bottom Offset"

msgid "啟用箭頭導覽"
msgstr "Enable arrow navigation"

msgid "啟用分頁點導覽"
msgstr "Enable pagination dots"

msgid "圖示預設值"
msgstr "Reset Icons"

msgid "自動輪播設定"
msgstr "Autoplay Settings"

msgid "設定輪播是否自動播放以及播放的間隔時間。"
msgstr "Set whether the slider plays automatically and how long each slide stays visible."

msgid "自動輪播間隔（毫秒）"
msgstr "Autoplay Interval (ms)"

msgid "開啟自動輪播"
msgstr "Enable autoplay"

msgid "自動輪播預設值"
msgstr "Reset Autoplay"

msgid "手動輪播 - 圖片選擇與排序"
msgstr "Manual Slider - Image Selection and Sorting"

msgid "此區域僅在「停用」自動抓取文章輪播時作用。用於手動新增、排序及設定輪播圖片。"
msgstr "This area is used only when the automatic post slider is disabled. Add, sort, and configure slider images manually here."

msgid "新增一組圖片"
msgstr "Add Image Set"

msgid "拖曳排序"
msgstr "Drag to Sort"

msgid "移除此組"
msgstr "Remove This Set"

msgid "桌機圖片預覽"
msgstr "Desktop image preview"

msgid "選擇桌機圖片"
msgstr "Select Desktop Image"

msgid "手機圖片預覽"
msgstr "Mobile image preview"

msgid "選擇手機圖片"
msgstr "Select Mobile Image"

msgid "移除手機圖"
msgstr "Remove Mobile Image"

msgid "連結網址"
msgstr "Link URL"

msgid "原視窗"
msgstr "Same Window"

msgid "新視窗"
msgstr "New Window"

msgid "*建議圖片寬度在 2000 px 以上"
msgstr "*Recommended image width is 2000 px or wider"

msgid "每組圖片可分別設定桌機與手機圖，連結與開啟方式共用"
msgstr "Each image set can have separate desktop and mobile images while sharing the same link and target."

msgid "WordPress 媒體庫功能未載入，請檢查是否有其他外掛衝突或 JavaScript 錯誤。"
msgstr "The WordPress media library did not load. Please check for plugin conflicts or JavaScript errors."

msgid "選擇此圖片"
msgstr "Use This Image"

msgid "在指定分類下找不到符合條件的文章或文章沒有精選圖片。"
msgstr "could not find matching posts with featured images in the selected category."

msgid "尚未設定圖片，或沒有有效的圖片。"
msgstr "has no configured images or no valid images."

msgid "沒有有效的圖片可供顯示。"
msgstr "has no valid images to display."

msgid "桌機輪播圖片"
msgstr "Desktop slider image"

msgid "手機輪播圖片"
msgstr "Mobile slider image"

msgid "輪播項目連結"
msgstr "Slider item link"

msgid "下一張"
msgstr "Next slide"

msgid "上一張"
msgstr "Previous slide"

msgid "輪播導覽點"
msgstr "Slider pagination"

msgid "上一張投影片"
msgstr "Previous slide"

msgid "下一張投影片"
msgstr "Next slide"

msgid "跳至投影片 {{index}}"
msgstr "Go to slide {{index}}"

msgid "這是第一張投影片"
msgstr "This is the first slide"

msgid "這是最後一張投影片"
msgstr "This is the last slide"

msgid "短代碼"
msgstr "Shortcode"

msgid "點擊以複製"
msgstr "Click to copy"

msgid "複製"
msgstr "Copy"

msgid "已複製！"
msgstr "Copied!"

msgid "複製失敗"
msgstr "Copy failed"
